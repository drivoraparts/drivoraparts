{
  "name": "drivoraparts",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "verify:cloudflare": "node scripts/verify-cloudflare-config.mjs",
    "audit:routes": "node scripts/audit-routes-opennext.mjs",
    "verify:opennext": "node scripts/verify-opennext-output.mjs",
    "pages:build": "node scripts/verify-cloudflare-config.mjs && npx opennextjs-cloudflare build && node scripts/patch-opennext-assets.mjs && node scripts/verify-opennext-output.mjs",
    "pages:deploy": "npx opennextjs-cloudflare deploy",
    "open-next:build": "npm run pages:build",
    "preview:cloudflare": "npm run pages:build && npx opennextjs-cloudflare preview",
    "deploy:cloudflare": "npm run pages:build && npx opennextjs-cloudflare deploy",
    "upload:cloudflare": "npm run pages:build && npx opennextjs-cloudflare upload",
    "start": "next start",
    "icons:generate": "node scripts/generate-brand-icons.mjs",
    "normalize:bodyparts": "node scripts/normalize-bodyparts-media.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@supabase/supabase-js": "^2.49.8",
    "@tailwindcss/postcss": "^4.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.0.0",
    "wrangler": "^4.103.0"
  }
}
